{
  "appId": "de.shinpai.kneipe",
  "appName": "Kneipenschlaegerei",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "cleartext": false,
    "allowNavigation": [
      "*.shinpai.de",
      "bar.shinpai.de",
      "*"
    ]
  },
  "android": {
    "allowMixedContent": false,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  }
}
